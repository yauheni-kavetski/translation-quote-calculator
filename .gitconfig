[user]
    name = Евгений Кавецкий
    email = your-email@example.com
[core]
    autocrlf = input
    quotepath = false
[init]
    defaultBranch = main
[commit]
    gpgsign = false
[push]
    default = simple
[core]
    editor = vim
[pull]
    rebase = false
[alias]
    st = status
    co = checkout
    br = branch
    ci = commit
    amend = commit --amend
    hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
